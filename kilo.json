{
  "$schema": "https://app.kilo.ai/config.json",
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "mcp": "allow",
    "env": "allow"
  },
  "mcp": {
    "openclaw-interceptor": {
      "type": "local",
      "command": ["bun", "run", "../mcp-server/src/index.js"],
      "enabled": true,
      "timeout": 30000
    }
  },
  "instructions": ["AGENTS.md"]
}
