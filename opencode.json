{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "openclaw-interceptor": {
      "type": "local",
      "command": ["bun", "run", "./mcp-server/src/index.js"],
      "enabled": true,
      "timeout": 30000
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "webfetch": "ask"
  }
}
