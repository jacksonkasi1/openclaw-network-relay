# ─── OpenClaw MCP Server — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values.
# Bun automatically loads .env on startup — no extra setup needed.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────


# ── Server ────────────────────────────────────────────────────────────────────

# Port the local HTTP server listens on.
# Default: 31337
# PORT=31337


# ── ChatGPT Custom GPT Bridge ─────────────────────────────────────────────────
#
# Set a strong random secret here to enable the Custom GPT REST bridge.
# The bridge exposes your MCP tools as OpenAPI Actions that ChatGPT can call.
#
# Generate a key with:
#   openssl rand -hex 32
#
# Leave blank (or omit) to keep the bridge disabled.
GPT_API_KEY=

# Set to "true" to automatically start a Cloudflare tunnel on server boot
# so the GPT bridge is immediately reachable without manually toggling SSE
# in the dashboard.  Useful when running the server as a background service.
# Default: false
# GPT_AUTO_TUNNEL=true


# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
#
# Two tunnel modes are supported (cloudflared CLI must be installed):
#   macOS:   brew install cloudflare/cloudflare/cloudflared
#   Linux:   https://pkg.cloudflare.com/index.html
#   Windows: winget install Cloudflare.cloudflared
#
#
# MODE A — Named tunnel with your Cloudflare account (RECOMMENDED)
# ----------------------------------------------------------------
# Gives a permanent, stable URL tied to your own domain.
# No more random URLs that change on every restart.
#
# How to get the token:
#   1. Go to https://one.dash.cloudflare.com/
#   2. Navigate to: Zero Trust → Networks → Tunnels
#   3. Click "Create a tunnel" → choose "Cloudflared" → name it (e.g. "openclaw")
#   4. Under "Install and run a connector", copy the token from the
#      install command:  cloudflared tunnel --no-autoupdate run --token <TOKEN>
#   5. In "Public Hostname", add a route:
#        Subdomain: openclaw  (or anything)
#        Domain:    yourdomain.com  (must be on Cloudflare)
#        Service:   http://localhost:31337
#   6. Paste the token below.
#
# CLOUDFLARE_TUNNEL_TOKEN=

# The public HTTPS URL of your named tunnel (required when using MODE A).
# This is the hostname you configured in the Cloudflare dashboard under
# "Public Hostname" for this tunnel, e.g.:
#   https://openclaw.yourdomain.com
#
# CLOUDFLARE_TUNNEL_URL=


# MODE B — Quick tunnel (no Cloudflare account needed)
# ----------------------------------------------------------------
# When CLOUDFLARE_TUNNEL_TOKEN is NOT set, the server falls back to
# a Quick Tunnel (trycloudflare.com).  The URL is random and changes
# every time the server restarts — but requires zero configuration.
#
# Quick Tunnels can occasionally return Cloudflare error 1033 if the
# infrastructure is under load.  Use Mode A for a reliable setup.
