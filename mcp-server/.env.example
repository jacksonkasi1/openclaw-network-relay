# ─── OpenClaw MCP Server — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values.
# Bun automatically loads .env on startup — no extra setup needed.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────


# ── Server ────────────────────────────────────────────────────────────────────

# Port the local HTTP server listens on.
# Default: 31337
# PORT=31337


# ── ChatGPT Custom GPT Bridge ─────────────────────────────────────────────────
#
# Set a strong random secret here to enable the Custom GPT REST bridge.
# The bridge exposes your MCP tools as OpenAPI Actions that ChatGPT can call.
#
# Generate a key with:
#   openssl rand -hex 32
#
# Leave blank (or omit) to keep the bridge disabled.
GPT_API_KEY=

# Set to "true" to automatically start a Cloudflare tunnel on server boot
# so the GPT bridge is immediately reachable without manually toggling SSE
# in the dashboard.  Useful when running the server as a background service.
# Default: false
# GPT_AUTO_TUNNEL=true
